# ────────────────────────────────────────────────────────────
# CheckingPlan capacity — backend configuration
# Copy this file to "server/.env" and fill in the real values
# ────────────────────────────────────────────────────────────

# Backend port (frontend Vite proxies /api/* to this port)
PORT=3001

# "mock" or "zoho"
#   mock → returns hardcoded sample tasks. App is usable end-to-end without setup.
#   zoho → real Zoho Projects REST API (requires OAuth credentials below)
MODE=mock

# ── Zoho Projects (only needed when MODE=zoho) ──────────────

# Data center: eu | com | in | com.au | jp
ZOHO_DC=eu

# Portal id (the conpas portal). Check via the "Get all portals" endpoint
# or inspect a Zoho Projects URL.
ZOHO_PORTAL_ID=20059477103

# OAuth credentials from https://api-console.zoho.eu/
# (use the matching DC: api-console.zoho.com / .in / etc.)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=

# Long-lived refresh token. See README → "Obtener un refresh_token de Zoho"
ZOHO_REFRESH_TOKEN=
